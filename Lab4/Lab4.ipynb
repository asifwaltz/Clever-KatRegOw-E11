    "data_url = \"Lab4Data.csv\"\n",
    "data = pd.read_csv(data_url)\n",
    "\n",
    "plt.hist(data[\"p25um\"])\n",
    "plt.title(\"Particles vs Time\")\n",
    "plt.xlabel(\"Time (Minutes)\")\n",
    "plt.ylabel(\"Particles (2.5um)\")\n",
    "plt.show()"
